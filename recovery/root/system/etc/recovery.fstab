# mount point fstype device flags
/system ext4 /dev/block/platform/bootdevice/by-name/system
/vendor ext4 /dev/block/platform/bootdevice/by-name/vendor display="Vendor";backup=1
/data ext4 /dev/block/platform/bootdevice/by-name/userdata flags=encryptable=footer
/cache ext4 /dev/block/platform/bootdevice/by-name/cache
/boot emmc /dev/block/platform/bootdevice/by-name/boot
/recovery emmc /dev/block/platform/bootdevice/by-name/recovery flags=backup=1
/efs ext4 /dev/block/platform/bootdevice/by-name/efs display="EFS";backup=1
/misc emmc /dev/block/platform/bootdevice/by-name/misc
/external_sd vfat /dev/block/mmcblk1p1 /dev/block/mmcblk1 flags=display="MicroSD";storage;wipeingui;removable
/usb_otg vfat /dev/block/sda1 /dev/block/sda flags=display="USB-OTG";storage;wipeingui;removable
